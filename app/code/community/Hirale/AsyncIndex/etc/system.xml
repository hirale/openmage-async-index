<?xml version="1.0"?>
<config>
    <sections>
        <hirale_asyncindex translate="label" module="hirale_asyncindex">
            <label>Async Index</label>
            <tab>hirale</tab>
            <sort_order>90</sort_order>
            <show_in_default>1</show_in_default>
            <show_in_website>0</show_in_website>
            <show_in_store>0</show_in_store>
            <groups>
                <settings translate="label" module="hirale_asyncindex">
                    <label>Settings</label>
                    <frontend_type>text</frontend_type>
                    <sort_order>10</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>0</show_in_website>
                    <show_in_store>0</show_in_store>
                    <fields>
                        <enabled translate="label comment" module="hirale_asyncindex">
                            <label>Enable Async Index</label>
                            <comment>Requires Hirale Queue to be installed and configured.</comment>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <backend_model>hirale_asyncindex/system_config_backend_enabled</backend_model>
                            <sort_order>10</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </enabled>
                        <auto_manage_modes translate="label comment" module="hirale_asyncindex">
                            <label>Auto Manage Index Modes</label>
                            <comment>When enabled, manual indexers are automatically switched to Update on Save so events are recorded.</comment>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <sort_order>15</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </auto_manage_modes>
                        <restore_modes_on_disable translate="label comment" module="hirale_asyncindex">
                            <label>Restore Modes on Disable</label>
                            <comment>Restore the modes that were active before Async Index took control.</comment>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <sort_order>16</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </restore_modes_on_disable>
                        <auto_reindex_required translate="label comment" module="hirale_asyncindex">
                            <label>Auto Queue Required Reindex</label>
                            <comment>Automatically enqueue full reindex runs when a process is marked Reindex Required.</comment>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <sort_order>17</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </auto_reindex_required>
                        <batch_size translate="label" module="hirale_asyncindex">
                            <label>Batch Size</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>20</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </batch_size>
                        <full_batch_size translate="label" module="hirale_asyncindex">
                            <label>Full Reindex Batch Size</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>25</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </full_batch_size>
                        <max_runtime_seconds translate="label" module="hirale_asyncindex">
                            <label>Max Runtime Seconds</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>30</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </max_runtime_seconds>
                        <full_max_runtime_seconds translate="label" module="hirale_asyncindex">
                            <label>Full Reindex Max Runtime Seconds</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>35</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </full_max_runtime_seconds>
                        <max_attempts translate="label" module="hirale_asyncindex">
                            <label>Max Attempts</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>50</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </max_attempts>
                        <retry_delay translate="label" module="hirale_asyncindex">
                            <label>Retry Delay Seconds</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>60</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </retry_delay>
                        <coalesce_ttl_seconds translate="label" module="hirale_asyncindex">
                            <label>Coalesce TTL Seconds</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>70</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </coalesce_ttl_seconds>
                    </fields>
                </settings>
            </groups>
        </hirale_asyncindex>
    </sections>
</config>
