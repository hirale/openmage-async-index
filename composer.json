{
    "name": "hirale/openmage-async-index",
    "type": "maho-module",
    "license": "OSL-3.0",
    "description": "Asynchronous Mage index event draining for Maho using hirale/queue.",
    "keywords": [
        "maho",
        "mahoecommerce",
        "magento1",
        "index",
        "queue"
    ],
    "require": {
        "php": ">=8.3",
        "mahocommerce/maho": "^26.5",
        "hirale/queue": "^3.0 || dev-master"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "config": {
        "allow-plugins": {
            "mahocommerce/maho-composer-plugin": true
        }
    },
    "autoload-dev": {
        "psr-4": { "HiraleAsyncIndex\\Tests\\": "tests/" }
    },
    "extra": {
        "maho-module-dir": "app/code/community/Hirale/AsyncIndex"
    },
    "scripts": {
        "test": "phpunit"
    },
    "authors": [
        { "name": "Hirale" }
    ]
}
