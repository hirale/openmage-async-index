{
    "name": "hirale/openmage-async-index",
    "description": "Asynchronous Mage index event draining for OpenMage and Maho using Hirale Redis Queue",
    "version": "dev-master",
    "type": "magento-module",
    "license": "OSL-3.0",
    "keywords": [
        "magento",
        "magento1",
        "maho",
        "mahoecommerce",
        "openmage",
        "index",
        "queue",
        "redis"
    ],
    "require": {
        "magento-hackathon/magento-composer-installer": "^3.0 || ^4.0 || ^99.99",
        "php": ">=8.1 <8.6",
        "hirale/openmage-redis-queue": "dev-master"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^12.5"
    },
    "config": {
        "allow-plugins": {
            "magento-hackathon/magento-composer-installer": false
        }
    },
    "conflict": {
        "mahocommerce/maho": "<25.9",
        "openmage/magento-lts": "<20.17"
    },
    "authors": [
        {
            "name": "Hirale"
        }
    ],
    "extra": {
        "map": [
            [
                "src/app/etc/modules/Hirale_AsyncIndex.xml",
                "app/etc/modules/Hirale_AsyncIndex.xml"
            ],
            [
                "src/app/code/community/Hirale/AsyncIndex",
                "app/code/community/Hirale/AsyncIndex"
            ]
        ]
    },
    "autoload": {
        "classmap": ["lib/MahoCLI/Commands/"]
    },
    "autoload-dev": {
        "psr-4": {
            "HiraleAsyncIndex\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
